# AutoPoV Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# =============================================================================
# Security
# =============================================================================
# Admin API key for generating new API keys (generate a strong random key)
ADMIN_API_KEY=your_admin_key_here

# Webhook secrets for validating incoming webhooks
WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret

# =============================================================================
# LLM Configuration - Online (OpenRouter)
# =============================================================================
# Get your API key from: https://openrouter.ai/keys
# OpenRouter supports multiple providers: OpenAI, Claude, Gemini, Grok, etc.
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Model selection (OpenRouter model IDs)
# Examples: openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-pro, x-ai/grok-beta
MODEL_MODE=online
MODEL_NAME=openai/gpt-4o

# =============================================================================
# LLM Configuration - Offline (Ollama)
# =============================================================================
# Uncomment these to use local models instead of OpenRouter
# MODEL_MODE=offline
# MODEL_NAME=llama3:70b
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# LangSmith Tracing (Optional)
# =============================================================================
# Enable for development/debugging
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_your_key_here
LANGCHAIN_PROJECT=autopov

# =============================================================================
# Git Provider Tokens (Optional)
# =============================================================================
# For accessing private repositories
GITHUB_TOKEN=ghp_your_token_here
GITLAB_TOKEN=glpat-your_token_here
BITBUCKET_TOKEN=your_token_here

# =============================================================================
# External Tools
# =============================================================================
# Paths to external tools (if not in PATH)
CODEQL_CLI_PATH=codeql
JOERN_CLI_PATH=joern
KAITAI_STRUCT_COMPILER_PATH=kaitai-struct-compiler

# =============================================================================
# Docker Configuration
# =============================================================================
DOCKER_ENABLED=true
DOCKER_IMAGE=python:3.12-slim

# =============================================================================
# Cost Control
# =============================================================================
MAX_COST_USD=100.0
COST_TRACKING_ENABLED=true

# =============================================================================
# Frontend URL (for CORS)
# =============================================================================
FRONTEND_URL=http://localhost:5173
