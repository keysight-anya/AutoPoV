# AutoPoV Backend Dockerfile with CodeQL and Docker-in-Docker support
FROM python:3.12-slim

# Set working directory
WORKDIR /app

# Install system dependencies including Docker, Node.js, and Semgrep dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    unzip \
    ca-certificates \
    gnupg \
    lsb-release \
    nodejs \
    npm \
    default-jdk \
    python3-dev \
    gcc \
    g++ \
    make \
    cmake \
    ninja-build \
    meson \
    autoconf \
    automake \
    libtool \
    pkg-config \
    file \
    libmagic1 \
    libffi-dev \
    binutils \
    && rm -rf /var/lib/apt/lists/*

# Install Docker CLI (for Docker-in-Docker)
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null \
    && apt-get update \
    && apt-get install -y docker-ce-cli docker-buildx-plugin docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

# Install CodeQL CLI (latest version 2.24.3) and query packs
RUN wget -q https://github.com/github/codeql-cli-binaries/releases/download/v2.24.3/codeql-linux64.zip -O /tmp/codeql.zip \
    && unzip -q /tmp/codeql.zip -d /usr/local \
    && rm /tmp/codeql.zip \
    && ln -s /usr/local/codeql/codeql /usr/local/bin/codeql

# Set CodeQL environment variable
ENV CODEQL_CLI_PATH=/usr/local/bin/codeql

# Download CodeQL standard query packs for primary supported languages.
# These are the languages where CodeQL provides taint analysis and deep semantic
# queries that Semgrep cannot replicate. Semgrep is used as fallback/supplemental
# for languages not listed here or when a CodeQL run fails.
# NOTE: no '|| true' — a failed pack download should fail the build loudly.
RUN mkdir -p /usr/local/codeql/packs \
    && codeql pack download --dir /usr/local/codeql/packs \
        codeql/cpp-queries \
        codeql/python-queries \
        codeql/javascript-queries \
        codeql/java-queries

# Install Joern CLI for CPG-based taint analysis (C/C++, Java, JS, Python)
# Download the pre-built zip directly — the install.sh script silently drops files
# into a versioned subdirectory that varies by release, making the symlink brittle.
RUN wget -q https://github.com/joernio/joern/releases/download/v4.0.341/joern-cli.zip \
    -O /tmp/joern-cli.zip \
    && unzip -q /tmp/joern-cli.zip -d /usr/local/joern \
    && rm /tmp/joern-cli.zip \
    && chmod +x /usr/local/joern/joern-cli/joern \
    && ln -sf /usr/local/joern/joern-cli/joern /usr/local/bin/joern \
    && joern --version

ENV JOERN_CLI_PATH=/usr/local/bin/joern

# Copy requirements first for better caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir --default-timeout=1000 -r requirements.txt     && npm install -g yarn pnpm     && python -m playwright install chromium

# Copy the application code
# Pass --build-arg CACHE_BUST=$(date +%s) to bust from this point forward.
ARG CACHE_BUST=1
COPY . .

# Create necessary directories
RUN mkdir -p data results/povs results/runs

# Expose the backend port
EXPOSE 8000

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV MODEL_MODE=online
ENV DOCKER_ENABLED=true

# Start the backend
CMD ["python", "-m", "app.main"]
